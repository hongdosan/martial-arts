# 공개 기본값 — 커밋 대상
#
# 이 파일은 프라이빗 설정 저장소 접근 권한이 없는 사용자도 앱을 Mock 모드로
# 기동할 수 있도록 하는 "최저선" 값을 담는다. CRA 가 자동 로드한다.
#
# - 실제 개발 값은 .env.dev (권한 있는 개발자) 또는 .env.example 복사본 (권한 없음)
# - 비밀 값(API 키, OAuth Secret 등)은 절대 여기에 넣지 않는다
# - 키 네이밍 · 코드 패턴은 docs/readme/env-var-convention.md 참조

REACT_APP_API_URL=https://mock-api.local
REACT_APP_OAUTH_ENABLED=false
REACT_APP_FEATURE_ANALYTICS=false
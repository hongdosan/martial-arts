# 개발 환경 변수 템플릿 — 커밋 대상
#
# 용도:
#   - 권한 없는 사용자: scripts/init-private.sh 가 이 파일을 .env.dev 로 자동 복사
#     (더미 값으로 Mock 모드 기동)
#   - 권한 있는 개발자: .private-config/frontend/env/.env.dev 를 symlink 로 사용
#     (이 파일은 신규 키가 추가됐을 때 싱크 맞추기용 참고 템플릿)
#
# 규칙:
#   - 모든 실제 사용 키를 여기에 더미 값으로 먼저 등록한다
#   - 비밀 값 대신 `your_<설명>_here` 형태의 플레이스홀더만 기입
#   - 새 키 추가 시 .env (공개 기본값) · .env.example (템플릿) 동시 갱신
#
# 자세한 규약은 docs/readme/env-var-convention.md 참조

REACT_APP_API_URL=https://your-api.example.com
REACT_APP_OAUTH_ENABLED=true
REACT_APP_OAUTH_CLIENT_ID=your_oauth_client_id_here
REACT_APP_FEATURE_ANALYTICS=true